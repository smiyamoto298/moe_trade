APP_NAME="MoE Trade"
APP_ENV=local
APP_KEY=
EMAIL_HASH_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# 相場データ: true にすると同一IP取引も相場対象外にせず全件を有効扱いにする。
# ローカルで出品者・購入者が同一IPになる手動検証時のみ true を推奨（既定 false）。
TREAT_ALL_TRADES_VALID=false
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=moe_trade
DB_USERNAME=moe_user
DB_PASSWORD=secret

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# 本番データのローカル取込（`php artisan db:pull-prod` / 管理ヘッダーの「本番データ取込」）用。
# ローカル開発機にだけ実値を設定する。**本番サーバの .env には絶対に書かない**。
# 取得経路: 本番サーバは外部からの 3306 を遮断しているため SSHトンネル経由で接続する。
#   取込前にホスト側でトンネルを起動する（トンネルスクリプトは非公開の運用ドキュメント参照）。
#   PROD_DB_HOST はトンネル出口（Docker から見たホスト）、PORT はトンネルの待受ポートを指す。
# PROD_DB_HOST=host.docker.internal
# PROD_DB_PORT=13306
# PROD_DB_DATABASE=アカウント名_moe_trade
# PROD_DB_USERNAME=
# PROD_DB_PASSWORD=

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@moe-trade.example"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost
