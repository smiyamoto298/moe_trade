APP_NAME="MoE Trade"
APP_ENV=local
APP_KEY=
EMAIL_HASH_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# 相場データ: true にすると同一IP取引も相場対象外にせず全件を有効扱いにする。
# ローカルで出品者・購入者が同一IPになる手動検証時のみ true を推奨（既定 false）。
TREAT_ALL_TRADES_VALID=false
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=moe_trade
DB_USERNAME=moe_user
DB_PASSWORD=secret

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@moe-trade.example"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost
