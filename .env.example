# docker compose 用の環境変数（ルートの .env として置くと自動で読み込まれる）。
#
# main の作業ディレクトリでは .env を置かず、ここにあるデフォルト（=従来値）のまま使う。
# git worktree で機能を平行開発するときだけ、worktree ごとに .env を作って
# プロジェクト名とホストポートをずらし、複数スタックを同時に立ち上げられるようにする。
#
# 生成は scripts/new-worktree.ps1 が自動でやる（手書きは不要）。手で作る場合の雛形:

# スタックを区別する名前。named volume(db_data など)もこの名前で分離される。
# COMPOSE_PROJECT_NAME=moe_featurex

# ホスト公開ポート（コンテナ内部ポートは固定。サービス間通信はサービス名解決なので影響なし）
# NGINX_PORT=8101         # ブラウザでアクセスする入口
# VITE_PORT=5174          # Vite dev server（HMR）
# DB_PORT=3307            # MySQL（ホストから接続する場合のみ関係）
# PMA_PORT=8201           # phpMyAdmin
# MAILPIT_UI_PORT=8301    # Mailpit Web UI
# MAILPIT_SMTP_PORT=1026  # Mailpit SMTP
